---
// Tab buttons for the English / Hindi medium switcher.
// Panels are rendered by the page as .wing-panel[data-wing]; toggling logic
// lives in BaseLayout so the chosen wing persists across pages.
---
<div class="wing-tabs">
  <button class="wing-tab" data-wing="english" type="button">English Medium</button>
  <button class="wing-tab" data-wing="hindi" type="button">हिंदी माध्यम</button>
</div>
