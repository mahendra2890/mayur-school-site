---
// Circular photo, or a striped placeholder when no photo is uploaded yet.
interface Props {
  photo?: string;
  name: string;
  size: number;
  ring: 'blue' | 'gold';
}
const { photo, name, size, ring } = Astro.props;
const style = `width:${size}px;height:${size}px`;
---
{photo ? (
  <div class:list={['avatar', `ring-${ring}`]} style={style}>
    <img src={photo} alt={name} loading="lazy" width={size} height={size} />
  </div>
) : (
  <div class:list={['avatar', 'ph', `ring-${ring}`, ring === 'gold' ? 'ph-gold' : 'ph-blue']} style={style}>
    <span style="font-size:8px">photo</span>
  </div>
)}
