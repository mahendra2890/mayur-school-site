---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

const site = (await getEntry('settings', 'site'))!.data;
---
<BaseLayout
  title="Contact & How to Reach — Mayur Children Sr. Sec. School, Badu"
  description="Address, phone, email, office hours and enquiry form for Mayur Children Sr. Sec. School, Village Badu."
>
  <PageHero crumb="Contact & How to Reach" title="Contact & How to Reach · संपर्क" subtitle="Visit us, call us, or send an enquiry." />

  <div class="container section contact-grid">
    <div>
      {site.mapEmbedUrl ? (
        <iframe
          src={site.mapEmbedUrl}
          class="map"
          style="border:0"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="School location on Google Maps"
        ></iframe>
      ) : (
        <div class="ph ph-green map map-ph">map: Google Maps embed appears here once configured</div>
      )}

      <div class="card card-pad" style="margin-bottom:18px">
        <div class="block-title">Address · पता</div>
        <p class="address">{site.addressLines.map((l) => <Fragment>{l}<br /></Fragment>)}</p>
        <div class="contact-lines">
          ☎ School office: <a href={`tel:${site.phone.replace(/[^+\d]/g, '')}`}><strong>{site.phone}</strong></a><br />
          ✉ <a href={`mailto:${site.email}`}><strong>{site.email}</strong></a><br />
          Office hours: {site.officeHours}
        </div>
      </div>

      <div class="note-box">
        <strong>How to reach · कैसे पहुँचें</strong><br />
        · 2 km from Badu bus stand — autos available all day<br />
        · School buses cover 12 nearby villages (<a href="/downloads" style="font-weight:700;text-decoration:none">route list</a>)<br />
        · Landmark: next to the water tower on Tehsil Road
      </div>
    </div>

    <div class="card form-card">
      <div class="block-title">Send an enquiry · पूछताछ भेजें</div>
      <p class="form-sub">The office replies within 1–2 working days.</p>
      <form id="enquiry-form">
        <input type="hidden" name="access_key" value={site.web3formsKey} />
        <input type="hidden" name="subject" value="Website enquiry — Mayur School" />
        <input type="checkbox" name="botcheck" class="honeypot" tabindex="-1" autocomplete="off" />
        <div class="field">
          <label for="f-name">Parent's name · अभिभावक का नाम</label>
          <input id="f-name" type="text" name="name" placeholder="Your name" required />
        </div>
        <div class="field">
          <label for="f-phone">Phone · फ़ोन</label>
          <input id="f-phone" type="tel" name="phone" placeholder="10-digit mobile" pattern="[0-9+\- ]{10,15}" required />
        </div>
        <div class="field">
          <label for="f-medium">Medium of interest · माध्यम</label>
          <select id="f-medium" name="medium">
            <option>English Medium</option>
            <option>हिंदी माध्यम</option>
            <option>Not sure yet · अभी तय नहीं</option>
          </select>
        </div>
        <div class="field">
          <label for="f-message">Message · संदेश</label>
          <textarea id="f-message" name="message" rows="4" placeholder="Admission enquiry for Class …" required></textarea>
        </div>
        <button type="submit" class="btn btn-gold submit-btn">Submit enquiry →</button>
        <p class="form-status" id="form-status" role="status"></p>
      </form>
    </div>
  </div>

  <script>
    const form = document.getElementById('enquiry-form') as HTMLFormElement;
    const status = document.getElementById('form-status')!;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button')!;
      btn.disabled = true;
      status.textContent = 'Sending… भेजा जा रहा है…';
      status.className = 'form-status';
      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: new FormData(form),
        });
        const data = await res.json();
        if (data.success) {
          form.reset();
          status.textContent = '✓ Enquiry sent. The office will contact you soon. · पूछताछ भेज दी गई है।';
          status.classList.add('ok');
        } else {
          throw new Error(data.message);
        }
      } catch {
        status.textContent = 'Could not send. Please call the school office instead. · कृपया कार्यालय में फ़ोन करें।';
        status.classList.add('err');
      } finally {
        btn.disabled = false;
      }
    });
  </script>
</BaseLayout>

<style>
  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; align-items: start; }
  @media (max-width: 800px) { .contact-grid { grid-template-columns: 1fr; } }

  .map { width: 100%; height: 230px; border-radius: var(--radius); margin-bottom: 22px; }
  .map-ph { border: 1px dashed #9DBCA8; font-size: 12px; }

  .block-title { font-family: var(--font-serif); font-weight: 600; font-size: 19px; color: var(--green-deep); margin-bottom: 10px; }
  .address { margin: 0 0 12px; font-size: 15px; color: var(--ink-body); line-height: 1.7; }
  .contact-lines { font-size: 14.5px; color: var(--ink-body); line-height: 1.9; }
  .contact-lines a { color: inherit; text-decoration: none; }

  .form-card { padding: 26px 28px; }
  .form-sub { margin: 0 0 18px; font-size: 14px; color: var(--ink-muted); }
  form { display: flex; flex-direction: column; gap: 14px; }
  .field label { display: block; font-weight: 700; font-size: 13.5px; color: var(--green-deep); margin-bottom: 5px; }
  .field input, .field select, .field textarea {
    width: 100%; box-sizing: border-box; border: 1.5px solid var(--border); border-radius: 6px;
    padding: 11px 14px; font-family: var(--font-sans); font-size: 14.5px;
    background: var(--bg-row-head); color: var(--ink);
  }
  .field textarea { resize: vertical; }
  .honeypot { display: none; }
  .submit-btn { font-size: 15.5px; padding: 13px; }
  .submit-btn:disabled { opacity: .6; cursor: wait; }
  .form-status { margin: 0; font-size: 14px; font-weight: 600; min-height: 1.4em; }
  .form-status.ok { color: #2E7D4F; }
  .form-status.err { color: #B4452E; }
</style>
