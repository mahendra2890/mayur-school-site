---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { dayMonth } from '../lib/utils';

const site = (await getEntry('settings', 'site'))!.data;
const cal = (await getEntry('calendar', 'calendar'))!.data;
const events = (await getCollection('events'))
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
---
<BaseLayout
  title="Academic Calendar — Mayur Children Sr. Sec. School, Badu"
  description={`Academic calendar for session ${site.session} — terms, upcoming events and holidays. Common for both wings.`}
>
  <PageHero crumb="Academic Calendar" title="Academic Calendar · शैक्षणिक कैलेंडर" subtitle={`Session ${site.session} · Common for both wings.`} />

  <div class="container section cal-grid">
    <div>
      <h2 class="section-title" style="font-size:24px">Upcoming events</h2>
      <div class="card rowlist">
        {events.map((e) => {
          const d = dayMonth(e.data.date);
          return (
            <div class="event-row">
              <div class="event-date">{d.day}<br />{d.month}</div>
              <div>
                <div class="event-title">{e.data.title}</div>
                <div class="event-detail">{e.data.detail}</div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
    <div>
      <h2 class="section-title" style="font-size:24px">Session at a glance</h2>
      <div class="card card-pad" style="margin-bottom:18px">
        {cal.terms.map((t) => (
          <div class="term-row"><span>{t.name}</span><span>{t.range}</span></div>
        ))}
      </div>
      <div class="note-box">
        <strong>Key holidays · मुख्य अवकाश</strong><br />
        {cal.holidays.map((h) => <Fragment>{h.name} · {h.date}<br /></Fragment>)}
      </div>
      <a href="/downloads" class="btn btn-green dl-btn">Download full holiday list (PDF)</a>
    </div>
  </div>
</BaseLayout>

<style>
  .cal-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 30px; align-items: start; }
  @media (max-width: 800px) { .cal-grid { grid-template-columns: 1fr; } }

  .event-row { display: flex; gap: 18px; padding: 16px 22px; align-items: center; }
  .event-date {
    color: var(--gold-dark); font-family: var(--font-serif); font-weight: 700;
    font-size: 15px; flex: none; width: 56px; text-align: center; line-height: 1.3;
  }
  .event-title { font-weight: 700; font-size: 15.5px; color: var(--green-deep); }
  .event-detail { font-size: 13.5px; color: var(--ink-muted); }

  .term-row { display: flex; justify-content: space-between; gap: 12px; padding: 8px 0; border-bottom: 1px solid var(--divider); font-size: 14.5px; }
  .term-row:last-child { border-bottom: none; }
  .term-row span:first-child { font-weight: 700; color: var(--green-deep); }
  .term-row span:last-child { color: var(--ink-muted); text-align: right; }

  .dl-btn { display: block; margin-top: 18px; padding: 13px; }
</style>
